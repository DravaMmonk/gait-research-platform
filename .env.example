HF_ENVIRONMENT=local
HF_METADATA_DATABASE_URL=sqlite+pysqlite:///./.hf/local.db
HF_ARTIFACT_ROOT=.hf/artifacts
HF_QUEUE_BACKEND=in_memory
HF_DEFAULT_RUNNER=local
HF_PLACEHOLDER_WORKER_MODE=true
HF_RESEARCH_TOOL_EXECUTION_MODE=local_function
HF_FORMULA_EVALUATION_MODE=scaffold
HF_LLM_MODEL=gpt-4o-mini
HF_AZURE_BLOB_ACCOUNT_URL=https://example.blob.core.windows.net
HF_AZURE_BLOB_CONTAINER=hound-platform
HF_AZURE_SERVICE_BUS_NAMESPACE=hound-jobs
HF_AZURE_SERVICE_BUS_QUEUE=runs
